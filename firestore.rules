rules_version = '2';

// DocParse Firestore Security Rules
//
// Database: "docparse" (dedicated, separate from default)
//
// All access is server-side only via Cloud Run service account (ADC).
// The browser never touches this database — API key management goes
// through the Cloud Run API endpoints, not direct Firestore access.
//
// Collections:
//   api_keys/{hash}   — per-user API keys (hashed), tiers, quotas
//   usage_logs/{id}   — request-level usage tracking

service cloud.firestore {
  match /databases/{database}/documents {

    // API keys: server-side only (Cloud Run SA via ADC)
    match /api_keys/{keyDoc} {
      allow read, write: if false;
    }

    // Usage logs: server-side only
    match /usage_logs/{logDoc} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
