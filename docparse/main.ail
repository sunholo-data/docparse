  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: 0
  };

  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(blocks);
  println("");

  writeOutputs(doc, result, false, filepath, convertTarget)
}

-- Parse an EPUB document (ZIP of XHTML, pure AILANG)
func parseEpubDocument(filepath: string, useAI: bool, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing EPUB (pure AILANG, ZIP + XHTML) ---");
  println("");

  -- Extract metadata
  println("Extracting metadata...");
  let metadata = parseEpubMetadata(filepath);

  -- Parse content (image paths resolved to full ZIP paths in epub_parser)
  println("Parsing XHTML chapters...");
  let blocks = parseEpub(filepath);
  println("Extracted " ++ show(countBlocks(blocks)) ++ " blocks.");

  -- Resolve image references to binary data from EPUB ZIP
  println("Resolving embedded images...");
  let resolvedBlocks = resolveBlockImages(filepath, blocks);
  let imageCount = countBlocks(filterImages(resolvedBlocks));

  -- AI image descriptions (optional)
  let describedBlocks = if useAI && imageCount > 0 then {
    println("Describing " ++ show(imageCount) ++ " images with AI...");
    describeImages(resolvedBlocks)
  } else {
    if imageCount > 0
    then println("Images: " ++ show(imageCount) ++ " (pass 'describe' arg for AI descriptions)")
    else println("No images found.");
    resolvedBlocks
  };

  -- AI self-healing (fix tables with empty/ambiguous cells)
  let allBlocks = if useAI then {
    println("Enhancing blocks with AI (fixing tables, layout)...");
    enhanceBlocks(describedBlocks)
  } else describedBlocks;
  println("");

  let aiCalls = if useAI then imageCount else 0;
  let doc = {
    format: "epub",
    filename: filepath,
    metadata: metadata,
    blocks: allBlocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: aiCalls
  };

  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(allBlocks);
  println("");

  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

-- Parse an ODF document (ODT/ODP/ODS — pure AILANG, ZIP + ODF XML)
func parseOdfDocument(filepath: string, ext: string, useAI: bool, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  let odfType = if ext == "odt" then "text"
    else if ext == "odp" then "presentation"
    else if ext == "ods" then "spreadsheet"
    else "unknown";
  println("--- Parsing ODF " ++ odfType ++ " (pure AILANG, ZIP + XML) ---");
  println("");

  -- Extract metadata
  println("Extracting metadata...");
  let metadata = if ext == "odt" then parseOdtMetadata(filepath)
    else if ext == "odp" then parseOdpMetadata(filepath)
    else parseOdsMetadata(filepath);

  -- Extract headers/footers (ODT only, from styles.xml)
  let hdrFtrBlocks = if ext == "odt" then {
    println("Extracting headers/footers...");
    let hf = parseOdtHeadersFooters(filepath);
    println("Found " ++ show(countBlocks(hf)) ++ " header/footer blocks.");
    hf
  } else [];

  -- Parse content
  println("Parsing ODF XML...");
  let bodyBlocks = if ext == "odt" then parseOdt(filepath)
    else if ext == "odp" then parseOdp(filepath)
    else parseOds(filepath);
  let blocks = concat(bodyBlocks, hdrFtrBlocks);
  println("Extracted " ++ show(countBlocks(blocks)) ++ " blocks.");

  -- Resolve image references to binary data from ZIP
  println("Resolving embedded images...");
  let resolvedBlocks = resolveBlockImages(filepath, blocks);
  let imageCount = countBlocks(filterImages(resolvedBlocks));

  -- AI image descriptions (optional)
  let describedBlocks = if useAI && imageCount > 0 then {
    println("Describing " ++ show(imageCount) ++ " images with AI...");
    describeImages(resolvedBlocks)
  } else {
    if imageCount > 0
    then println("Images: " ++ show(imageCount) ++ " (pass 'describe' arg for AI descriptions)")
    else println("No images found.");
    resolvedBlocks
  };

  -- AI self-healing (fix tables with empty/ambiguous cells)
  let allBlocks = if useAI then {
    println("Enhancing blocks with AI (fixing tables, layout)...");
    enhanceBlocks(describedBlocks)
  } else describedBlocks;
  println("");

  let aiCalls = if useAI then imageCount else 0;
  let doc = {
    format: ext,
    filename: filepath,
    metadata: metadata,
    blocks: allBlocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: aiCalls
  };

  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(allBlocks);
  println("");

  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

-- Parse an HTML/XHTML document (pure AILANG, XML-based)
-- Strategy: try deterministic XML parse first, AI fallback for dirty HTML
func parseHtmlDocument(filepath: string, useAI: bool, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing HTML (pure AILANG, XML-based) ---");
  println("");

  let content = readFile(filepath);
  println("Parsing " ++ show(length(content)) ++ " chars of HTML...");

  -- Step 1: Try deterministic XML parsing
  let blocks = parseHtml(content);
  let hasError = htmlHasParseError(blocks);

  -- Step 2: If parse failed and AI is enabled, extract text via AI
  let resolvedBlocks = if hasError && useAI then {
    println("XML parse failed — extracting text content via AI...");
    let extracted = call(
      "Extract the text content from this HTML. Return the main text, preserving:" ++
      " paragraph breaks, headings, list items, and table data." ++
      " Ignore HTML tags, scripts, and styles. Return clean readable text.\n\n" ++
      content
    );
    [TextBlock({text: extracted, style: "ai-extracted", level: 0})]
  } else blocks;

  println("Extracted " ++ show(countBlocks(resolvedBlocks)) ++ " blocks.");

  -- Apply AI table enhancement (only if parse succeeded deterministically)
  let allBlocks = if useAI && hasError == false then {
    println("Enhancing blocks with AI (fixing tables, layout)...");
    enhanceBlocks(resolvedBlocks)
  } else resolvedBlocks;
  println("");

  let doc = {
    format: "html",
    filename: filepath,
    metadata: emptyMetadata(),
    blocks: allBlocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: 0
  };

  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(allBlocks);
  println("");

  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

-- Parse a plain text document
func parseTextDocument(filepath: string) -> () ! {IO, FS} {
  println("--- Parsing Text ---");
  let content = readFile(filepath);
  println("Content (" ++ show(length(content)) ++ " chars):");
  println(content);
  println("=== DocParse Complete ===")
}

-- Write all output files: JSON, markdown, optional conversion, and optional AI summary
-- Output filenames are derived from input: sample.docx → sample.docx.json, sample.docx.md
-- Output dir: DOCPARSE_OUTPUT_DIR env var (default: docparse/data)
-- convertTarget: if non-empty, generate output in target format (e.g., "out.html", "out.docx")
func writeOutputs(doc: ParsedDocument, result: ExtractionResult, doSummarize: bool, filepath: string, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  let outDir = getEnvOr("DOCPARSE_OUTPUT_DIR", "docparse/data");
  let basename = mainBasename(filepath);

  -- Write JSON
  let jsonOutput = formatResult(result);
  let jsonPath = outDir ++ "/" ++ basename ++ ".json";
  writeFile(jsonPath, jsonOutput);
  println("JSON output written to " ++ jsonPath);

  -- Write markdown (LLM-ready text)
  let markdown = renderMarkdown(doc);
  let mdPath = outDir ++ "/" ++ basename ++ ".md";
  writeFile(mdPath, markdown);
  println("Markdown output written to " ++ mdPath);

  -- Optional: format conversion
  if length(convertTarget) > 0 then {
    println("");
    let convertExt = getExtension(convertTarget);
    if convertExt == "html" || convertExt == "htm" then {
      let html = generateHtml(doc);
      writeFile(convertTarget, html);
      println("Converted to HTML: " ++ convertTarget)
    }
    else if convertExt == "docx" then {
      let msg = generateDocx(doc, convertTarget);
      println(msg)
    }
    else if convertExt == "pptx" then {
      let msg = generatePptx(doc, convertTarget);
      println(msg)
    }
    else if convertExt == "xlsx" then {
      let msg = generateXlsx(doc, convertTarget);
      println(msg)
    }
    else if convertExt == "odt" then {
      let msg = generateOdt(doc, convertTarget);
      println(msg)
    }
    else if convertExt == "odp" then {
      let msg = generateOdp(doc, convertTarget);
      println(msg)
    }
    else if convertExt == "ods" then {
      let msg = generateOds(doc, convertTarget);
      println(msg)
    }
    else if convertExt == "md" then {
      let md = renderMarkdown(doc);
      writeFile(convertTarget, md);
      println("Converted to Markdown: " ++ convertTarget)
    }
    else println("Unsupported conversion format: " ++ convertExt ++ " (supported: html, docx, pptx, xlsx, odt, odp, ods, md)")
  }
  else ();

  -- Optional: AI summary
  if doSummarize then {
    println("");
    println("--- AI Summary ---");
    let summary = call(
      "Summarize this document concisely. Include key points, data from any tables, " ++
      "and descriptions of any images. Output plain text, not markdown.\n\n" ++
      markdown
    );
    println(summary);
    println("");
    -- Write summary to file
    let summaryPath = outDir ++ "/" ++ basename ++ "_summary.txt";
    writeFile(summaryPath, summary);
    println("Summary written to " ++ summaryPath)
  }
  else ();

  println("");
  println("=== DocParse Complete ===")
}

-- Extract basename from a filepath: "/path/to/sample.docx" → "sample.docx"
pure func mainBasename(filepath: string) -> string {
  let parts = split(filepath, "/");
  match last(parts) {
    Some(name) => if length(name) > 0 then name else "output",
    None => "output"
  }
}

-- Check if parsed HTML blocks contain a parse error
-- The HTML parser returns TextBlock(style: "error") on parse failure
pure func htmlHasParseError(blocks: [Block]) -> bool =
  match blocks {
    [] => false,
    b :: rest => match b {
      TextBlock(t) => if t.style == "error" then true else htmlHasParseError(rest),
      _ => htmlHasParseError(rest)
    }
  }
