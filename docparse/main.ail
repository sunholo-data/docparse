-- DocParse: Universal Document Parsing in AILANG
--
-- Demonstrates:
--   - ZIP + XML parsing for Office formats (std/zip, std/xml)
--   - AI-augmented layout understanding with bounded costs
--   - Contracts on output quality
--   - Pure/effectful function separation
--   - Pattern matching on XML trees
--
-- Run (without AI):
--   ailang run --entry main --caps IO,FS,Env docparse/main.ail myfile.docx
--
-- Run (with AI image descriptions):
--   GOOGLE_API_KEY="" ailang run --entry main --caps IO,FS,Env,AI --ai gemini-3-flash-preview docparse/main.ail myfile.docx describe
--
-- Run (with contracts enforced):
--   ailang run --entry main --caps IO,FS,Env --verify-contracts docparse/main.ail myfile.docx
--
-- Test:
--   ailang test docparse/services/format_router.ail
--   ailang test docparse/services/docx_parser.ail
--
-- CAPABILITY BUDGETS:
--   IO @limit=1000  - Console output for results (increased for page-by-page PDF parsing)
--   FS @limit=100   - File reads (ZIP entries) + output write (increased from 20 for complex DOCX with headers/footers)
--   AI @limit=30   - PDF page-by-page parsing + image descriptions + layout inference

export func main() -> () ! {IO @limit=50000, FS @limit=5000, AI @limit=30, Env} {
  println("=== DocParse: Universal Document Parsing ===");
  println("");

  -- Get filepath and flags from CLI args
  let args = getArgs();
  let filepath = match args {
    [] => "docparse/data/sample.docx",
    f :: _ => f
  };
  let useAI = hasFlag(args, "describe");
  let doSummarize = hasFlag(args, "summarize");
  let convertTarget = getConvertTarget(args);
  let generateTarget = getGenerateTarget(args);
  let promptText = getPromptText(args);

  -- AI Document Generation mode: --generate output.docx --prompt "..."
  if length(generateTarget) > 0 && length(promptText) > 0 then {
    generateDocument(generateTarget, promptText)
  }
  else if length(generateTarget) > 0 then {
    println("Error: --generate requires --prompt \"description\"");
    println("");
    println("Usage: ./bin/docparse --generate report.docx --prompt \"Q1 sales report with tables\"");
    println("       ./bin/docparse --generate slides.pptx --prompt \"5-slide pitch deck\"")
  }
  -- Check file exists (normal parse mode)
  else if not fileExists(filepath) then {
    println("Error: File not found: " ++ filepath);
    println("");
    println("Usage: ailang run --entry main --caps IO,FS,Env docparse/main.ail <file>");
    println("       ailang run --entry main --caps IO,FS,Env,AI --ai gemini-3-flash-preview docparse/main.ail <file> describe");
    println("       ailang run --entry main --caps IO,FS,Env,AI --ai gemini-3-flash-preview docparse/main.ail <file> summarize");
    println("       ailang run --entry main --caps IO,FS,Env,AI --ai gemini-2.5-flash docparse/main.ail --generate output.docx --prompt \"...\"")
  }
  else {
    -- Step 1: Detect format
    let ext = getExtension(filepath);
    let format = detectFormat(ext);
    let strategy = strategyDescription(format);
    println("File:     " ++ filepath);
    println("Format:   " ++ format ++ " (" ++ ext ++ ")");
    println("Strategy: " ++ strategy);
    let aiRequired = needsAI(format);
    if aiRequired then println("AI:       required (format needs AI extraction)")
    else if doSummarize then println("AI:       enabled (summarize)")
    else if useAI then println("AI:       enabled (image descriptions)")
    else println("AI:       disabled (pass 'describe' or 'summarize' arg to enable)");
    println("");

    -- Step 2: Parse based on format
    match format {
      "zip-office" => parseOfficeDocument(filepath, ext, useAI || doSummarize, doSummarize, convertTarget),
      "pdf" => parsePdfDocument(filepath, doSummarize, convertTarget),
      "image" => parseImageDocument(filepath, ext, doSummarize, convertTarget),
      "audio" => parseAudioDocument(filepath, ext, doSummarize, convertTarget),
      "video" => parseVideoDocument(filepath, ext, doSummarize, convertTarget),
      "csv" => parseCsvDocument(filepath, ext, convertTarget),
      "markdown" => parseMarkdownDocument(filepath, convertTarget),
      "html" => parseHtmlDocument(filepath, useAI || doSummarize, doSummarize, convertTarget),
      "epub" => parseEpubDocument(filepath, useAI || doSummarize, doSummarize, convertTarget),
      "zip-odf" => parseOdfDocument(filepath, ext, useAI || doSummarize, doSummarize, convertTarget),
      "text" => parseTextDocument(filepath),
      _ => println("Format '" ++ format ++ "' not yet supported in this demo.")
    }
  }
}

-- Check if a flag is present in args list
pure func hasFlag(args: [string], flag: string) -> bool =
  any(\a. a == flag, args)

-- Extract --convert target path from args: ["file.docx", "--convert", "out.html"] -> "out.html"
pure func getConvertTarget(args: [string]) -> string =
  match args {
    [] => "",
    "--convert" :: rest => match rest {
      [] => "",
      target :: _ => target
    },
    _ :: rest => getConvertTarget(rest)
  }

-- Extract --generate target path from args: ["--generate", "out.docx", "--prompt", "..."] -> "out.docx"
pure func getGenerateTarget(args: [string]) -> string =
  match args {
    [] => "",
    "--generate" :: rest => match rest {
      [] => "",
      target :: _ => target
    },
    _ :: rest => getGenerateTarget(rest)
  }

-- Extract --prompt text from args: ["--prompt", "Q1 report"] -> "Q1 report"
pure func getPromptText(args: [string]) -> string =
  match args {
    [] => "",
    "--prompt" :: rest => match rest {
      [] => "",
      text :: _ => text
    },
    _ :: rest => getPromptText(rest)
  }

-- AI Document Generation: prompt → AI → [Block] → format generator → file
func generateDocument(outputPath: string, prompt: string) -> () ! {IO, FS, AI, Env} {
  let ext = getExtension(outputPath);
  println("--- AI Document Generation ---");
  println("Output:   " ++ outputPath);
  println("Format:   " ++ ext);
  println("Prompt:   " ++ prompt);
  println("");

  -- Step 1: Generate blocks from prompt via AI
  println("Generating content via AI...");
  let blocks = aiGenerateBlocks(prompt, ext);
  println("Generated " ++ show(countBlocks(blocks)) ++ " content blocks.");
  println("");

  -- Step 2: Build a ParsedDocument wrapper
  let doc = {
    format: ext,
    filename: outputPath,
    metadata: {title: prompt, author: "DocParse AI", created: "", modified: "", pageCount: 0},
    blocks: blocks
  };

  -- Step 3: Show what was generated
  printSummary(doc);
  println("");
  println("--- Generated Content ---");
  printBlocks(blocks);
  println("");

  -- Step 4: Generate the output file
  if ext == "html" || ext == "htm" then {
    let html = generateHtml(doc);
    writeFile(outputPath, html);
    println("Generated HTML: " ++ outputPath)
  }
  else if ext == "docx" then {
    let msg = generateDocx(doc, outputPath);
    println(msg)
  }
  else if ext == "pptx" then {
    let msg = generatePptx(doc, outputPath);
    println(msg)
  }
  else if ext == "xlsx" then {
    let msg = generateXlsx(doc, outputPath);
    println(msg)
  }
  else if ext == "odt" then {
    let msg = generateOdt(doc, outputPath);
    println(msg)
  }
  else if ext == "odp" then {
    let msg = generateOdp(doc, outputPath);
    println(msg)
  }
  else if ext == "ods" then {
    let msg = generateOds(doc, outputPath);
    println(msg)
  }
  else if ext == "md" then {
    let md = renderMarkdown(doc);
    writeFile(outputPath, md);
    println("Generated Markdown: " ++ outputPath)
  }
  else println("Unsupported format: " ++ ext ++ " (supported: html, docx, pptx, xlsx, odt, odp, ods, md)");

  println("");
  println("=== DocParse Generation Complete ===")
}

-- Parse an Office document (docx/pptx/xlsx)
func parseOfficeDocument(filepath: string, ext: string, useAI: bool, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  let office = officeType(ext);
  match office {
    "word" => parseWordDocument(filepath, useAI, doSummarize, convertTarget),
    "powerpoint" => parsePowerPointDocument(filepath, useAI, doSummarize, convertTarget),
    "excel" => parseExcelDocument(filepath, doSummarize, convertTarget),
    _ => println("Office type '" ++ office ++ "' not yet supported.")
  }
}

-- Parse a Word (DOCX) document
func parseWordDocument(filepath: string, useAI: bool, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing DOCX ---");
  println("");

  -- Step 2a: Extract metadata
  println("Extracting metadata...");
  let metadata = parseDocxMetadata(filepath);

  -- Step 2b: Parse document content (pure XML parsing)
  println("Parsing document XML...");
  let blocks = parseDocx(filepath);
  println("Extracted " ++ show(countBlocks(blocks)) ++ " content blocks.");
  println("");

  -- Step 2c: Extract headers and footers
  println("Extracting headers/footers...");
  let headerBlocks = parseDocxHeaders(filepath);
  let footerBlocks = parseDocxFooters(filepath);
  println("Found " ++ show(countBlocks(headerBlocks)) ++ " headers, " ++ show(countBlocks(footerBlocks)) ++ " footers.");

  -- Step 2d: Extract footnotes and endnotes
  println("Extracting footnotes/endnotes...");
  let footnoteBlocks = parseDocxFootnotes(filepath);
  let endnoteBlocks = parseDocxEndnotes(filepath);
  println("Found " ++ show(countBlocks(footnoteBlocks)) ++ " footnotes, " ++ show(countBlocks(endnoteBlocks)) ++ " endnotes.");

  -- Step 2e: Extract comments
  println("Extracting comments...");
  let commentBlocks = parseDocxComments(filepath);
  println("Found " ++ show(countBlocks(commentBlocks)) ++ " comments.");

  -- Step 2f: Extract embedded images
  println("Extracting images...");
  let imageBlocks = parseDocxImages(filepath);
  println("Found " ++ show(countBlocks(imageBlocks)) ++ " embedded images.");
  println("");

  -- Combine all blocks: headers + body + footers + footnotes + endnotes + comments + images
  let combinedBlocks = concat(headerBlocks,
    concat(blocks,
      concat(footerBlocks,
        concat(footnoteBlocks,
          concat(endnoteBlocks,
            concat(commentBlocks, imageBlocks))))));

  -- Step 2f: AI image descriptions (optional)
  let imageCount = countBlocks(filterImages(combinedBlocks));
  let describedBlocks = if useAI && imageCount > 0 then {
    println("Describing " ++ show(imageCount) ++ " images with AI...");
    describeImages(combinedBlocks)
  } else {
    if imageCount > 0
    then println("Images: " ++ show(imageCount) ++ " (pass 'describe' arg for AI descriptions)")
    else println("No images found.");
    combinedBlocks
  };

  -- Step 2g: AI self-healing (fix tables with empty/ambiguous cells)
  let allBlocks = if useAI then {
    println("Enhancing blocks with AI (fixing tables, layout)...");
    enhanceBlocks(describedBlocks)
  } else describedBlocks;

  -- Step 3: Build result
  let aiCalls = if useAI then imageCount else 0;
  let doc = {
    format: "docx",
    filename: filepath,
    metadata: metadata,
    blocks: allBlocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: aiCalls
  };

  -- Step 4: Output
  println("");
  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(allBlocks);
  println("");

  -- Step 5: Write outputs
  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

-- Parse a PowerPoint (PPTX) document
func parsePowerPointDocument(filepath: string, useAI: bool, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing PPTX ---");
  println("");

  -- Step 2a: Extract metadata
  println("Extracting metadata...");
  let metadata = parsePptxMetadata(filepath);

  -- Step 2b: Parse all slides
  println("Parsing slides...");
  let blocks = parsePptx(filepath);
  println("Extracted " ++ show(countBlocks(blocks)) ++ " slide blocks.");
  println("");

  -- Step 2c: Extract embedded images
  println("Extracting images...");
  let imageBlocks = parsePptxImages(filepath);
  println("Found " ++ show(countBlocks(imageBlocks)) ++ " embedded images.");
  println("");

  -- Combine slide blocks + images
  let combinedBlocks = concat(blocks, imageBlocks);

  -- Step 2d: AI image descriptions (optional)
  let imageCount = countBlocks(filterImages(combinedBlocks));
  let describedBlocks = if useAI && imageCount > 0 then {
    println("Describing " ++ show(imageCount) ++ " images with AI...");
    describeImages(combinedBlocks)
  } else {
    if imageCount > 0
    then println("Images: " ++ show(imageCount) ++ " (pass 'describe' arg for AI descriptions)")
    else println("No images found.");
    combinedBlocks
  };

  -- Step 2e: AI self-healing (fix tables with empty/ambiguous cells)
  let allBlocks = if useAI then {
    println("Enhancing blocks with AI (fixing tables, layout)...");
    enhanceBlocks(describedBlocks)
  } else describedBlocks;

  -- Step 3: Build result
  let aiCalls = if useAI then imageCount else 0;
  let doc = {
    format: "pptx",
    filename: filepath,
    metadata: metadata,
    blocks: allBlocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: aiCalls
  };

  -- Step 4: Output
  println("");
  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(allBlocks);
  println("");

  -- Step 5: Write outputs
  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

