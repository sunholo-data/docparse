-- Parse a CSV/TSV document (pure AILANG, no dependencies)
func parseCsvDocument(filepath: string, ext: string, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing CSV (pure AILANG) ---");
  println("");

  let content = readFile(filepath);
  let delimiter = if ext == "tsv" then "\t" else ",";
  println("Parsing " ++ show(length(content)) ++ " chars with delimiter '" ++ delimiter ++ "'...");

  let blocks = parseCsv(content, delimiter);
  println("Extracted " ++ show(countBlocks(blocks)) ++ " blocks.");
  println("");

  let doc = {
    format: ext,
    filename: filepath,
    metadata: emptyMetadata(),
    blocks: blocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: 0
  };

  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(blocks);
  println("");

  writeOutputs(doc, result, false, filepath, convertTarget)
}

-- Parse a Markdown document (pure AILANG, no dependencies)
func parseMarkdownDocument(filepath: string, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing Markdown (pure AILANG) ---");
