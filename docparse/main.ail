-- Parse a PDF document (AI-powered extraction)
func parsePdfDocument(filepath: string, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing PDF (AI) ---");
  println("");

  -- Step 2a: Extract metadata via AI
  println("Extracting metadata via AI...");
  let metadata = parsePdfMetadata(filepath);

  -- Step 2b: Extract content via AI
  println("Extracting content via AI...");
  let blocks = parsePdf(filepath);
  println("Extracted " ++ show(countBlocks(blocks)) ++ " content blocks.");
  println("");

  -- Step 3: Build result
  let aiCalls = 1 + (if countBlocks(blocks) > 0 then 1 else 0);
  let doc = {
    format: "pdf",
    filename: filepath,
    metadata: metadata,
    blocks: blocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: aiCalls
  };

  -- Step 4: Output
  println("");
  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(blocks);
  println("");

  -- Step 5: Write outputs
  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

-- Parse an image file (AI-powered document extraction)
-- Extracts structured content (headings, text, tables) from document page images.
-- Falls back to image description if no document content is found.
func parseImageDocument(filepath: string, ext: string, doSummarize: bool, convertTarget: string) -> () ! {IO, FS, AI, Env} {
  println("--- Parsing Image (AI Document Extraction) ---");
  println("");

  let mime = imageMimeType(ext);
  println("Extracting document content from image via AI...");
  let blocks = parseDocumentImage(filepath, mime);
  let finalBlocks = match blocks {
    [] => {
      println("No document content found, falling back to image description...");
      parseImage(filepath, mime)
    },
    _ => blocks
  };
  println("Generated " ++ show(countBlocks(finalBlocks)) ++ " content blocks.");
  println("");

  -- Build result
  let doc = {
    format: ext,
    filename: filepath,
    metadata: emptyMetadata(),
    blocks: finalBlocks
  };

  let result = {
    document: doc,
    warnings: [],
    aiCallsUsed: 1
  };

  -- Output
  printSummary(doc);
  println("");
  println("--- Content Blocks ---");
  printBlocks(finalBlocks);
  println("");

  -- Write outputs
  writeOutputs(doc, result, doSummarize, filepath, convertTarget)
}

-- Determine MIME type from image extension
pure func imageMimeType(ext: string) -> string =
  match ext {
    "png" => "image/png",
    "jpg" => "image/jpeg",
    "jpeg" => "image/jpeg",
    "gif" => "image/gif",
    "bmp" => "image/bmp",
    "webp" => "image/webp",
    "tiff" => "image/tiff",
    _ => "image/unknown"
  }

